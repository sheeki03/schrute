{
  "name": "schrute",
  "version": "0.1.1",
  "description": "Universal Self-Learning Browser Agent — UI automation for the first run, API-level replay for the 100th run",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./cli": {
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "schrute": "dist/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/sync-version.js",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "node scripts/sync-version.js && npm run build",
    "build:native": "cd native && cargo build --release && cp target/release/libschrute_native.dylib index.node 2>/dev/null; cp target/release/schrute_native.dll index.node 2>/dev/null; cp target/release/libschrute_native.so index.node 2>/dev/null; echo 'Native build complete'",
    "dev": "tsc -w -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "serve": "node dist/index.js serve",
    "setup": "node dist/index.js setup",
    "doctor": "node dist/index.js doctor",
    "rebuild:native": "bash scripts/rebuild-native.sh",
    "build:binary": "npm run build && pkg dist/index.js --config pkg.config.json",
    "build:binary:macos": "npm run build:binary -- --target node22-macos-arm64",
    "build:binary:linux": "npm run build:binary -- --target node22-linux-x64",
    "postinstall": "npx --yes playwright install chromium 2>/dev/null || echo 'Playwright browser install skipped (run: npx playwright install chromium)'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "fastify": "^5.2.1",
    "ipaddr.js": "^2.2.0",
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "patchright": "^1.57.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "pngjs": "^7.0.0",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "camoufox-js": "^0.8.5"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/pngjs": "^6.0.0",
    "@yao-pkg/pkg": "^6.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sheeki03/schrute"
  },
  "homepage": "https://github.com/sheeki03/schrute#readme",
  "bugs": {
    "url": "https://github.com/sheeki03/schrute/issues"
  },
  "author": "Schrute Contributors",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser-automation",
    "api-replay",
    "playwright",
    "skill-learning",
    "schrute"
  ],
  "files": [
    "dist/",
    ".claude-plugin/",
    "commands/",
    "skills/",
    "agents/",
    "hooks/",
    "prompts/",
    ".mcp.json",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CLAUDE.md",
    "AGENTS.md",
    "scripts/sync-version.js"
  ]
}
